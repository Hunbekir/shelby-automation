# ============================================================
# AI Shelby — Environment Variables
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env  (remove the .example)
# 2. Fill in your real API keys below
# 3. NEVER commit .env to GitHub — it is already in .gitignore
# ============================================================

# Anthropic Claude API key
# Get it from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Apify API token
# Get it from: https://console.apify.com → Settings → Integrations → Personal API Token
APIFY_API_TOKEN=your_apify_token_here

# Shelby's Skool User ID
# How to find it: Run the Apify actor with action "posts:list" for class-economy,
# look at the "createdBy.id" field on any post made by Shelby's account.
SHELBY_USER_ID=shelby_skool_user_id_here
